// Resend webhook — delivered via Svix.
//
// Svix constructs its signed payload from three separate headers:
//   svix-id:        unique message identifier
//   svix-timestamp: Unix timestamp
//   svix-signature: v1,<base64_sig1> v1,<base64_sig2>  (space-separated during key rotation)
//
// The secret is the value from the Resend dashboard, including the "whsec_"
// prefix. HookVault strips the prefix and base64-decodes the remainder before
// using it as the HMAC key.
{
  "providers": [
    {
      "name": "resend",
      "path": "/resend",
      "forwardUrl": "http://host.docker.internal:3000/webhooks/resend",
      "validation": {
        "scheme": "svix",
        "algorithm": "hmac-sha256",
        "secretEnvVar": "RESEND_WEBHOOK_SECRET"
      }
    }
  ]
}
