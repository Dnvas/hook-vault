# Build output
bin/
obj/
out/

# UI build output — populated by Docker stage 0 (ui-build) or a local
# `npm run build && cp -r ui/dist/* src/HookVault/wwwroot/`. Never committed.
src/HookVault/wwwroot/

# IDE / OS
.vs/
.vscode/
*.user
.DS_Store
Thumbs.db

# Rider
.idea/

# .NET secrets and local config
appsettings.Local.json
appsettings.*.Local.json
secrets.json

# SQLite databases (runtime data, not source)
*.db
*.db-shm
*.db-wal

# NuGet
*.nupkg
*.snupkg
.nuget/

# Test results
TestResults/
coverage/
*.coveragexml

# Docker
.env
.env.*

# HookVault runtime config (user-supplied, not committed to the repo)
hookvault.json

# Local AI assistant configuration — only the skills are shared with the repo
# so any contributor using Claude Code (or another agent) inherits the same
# project knowledge. Settings, local plans, and CLAUDE.local.md stay personal.
.claude/*
!.claude/skills/
!.claude/skills/**
CLAUDE.local.md
.superpowers/

# Playwright MCP browser session artifacts
.playwright-mcp/
